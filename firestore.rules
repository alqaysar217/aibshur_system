rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // This function checks if the signed-in user has an 'admin' role in their user document.
    function isAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // --- DEVELOPMENT ONLY: Temporarily open rules for admin panel ---
    // These rules are insecure and should be locked down before production.
    match /cities/{cityId} {
      allow read, write: if true; // DEV-ONLY: Open write access
    }

    match /store_categories/{categoryId} {
      allow read, write: if true; // DEV-ONLY: Open write access
    }

    match /stores/{storeId} {
      allow read, write: if true; // DEV-ONLY: Open write access
    }

    match /product_categories/{prodCatId} {
      allow read, write: if true; // DEV-ONLY: Open write access
    }

    match /products/{productId} {
        allow read, write: if true; // DEV-ONLY: Open write access
    }

    match /products/{productId}/variants/{variantId} {
      allow read, write: if true; // DEV-ONLY: Open write access
    }

    match /orders/{orderId} {
      allow read, write: if true; // DEV-ONLY: Open write access
    }

    match /ad_banners/{bannerId} {
      allow read, write: if true; // DEV-ONLY: Open write access
    }

    match /coupons/{couponId} {
      allow read, write: if true; // DEV-ONLY: Open write access
    }

    match /app_banks/{bankId} {
      allow read, write: if true; // DEV-ONLY: Open write access
    }

    match /wallet_transactions/{transactionId} {
      allow read, write: if true; // DEV-ONLY: Open write access
    }
    
    match /donations/{donationId} {
      allow read, write: if true; // DEV-ONLY: Open write access
    }

    match /financeTransactions/{transactionId} {
      allow read, write: if true; // DEV-ONLY: Open write access
    }
    
    match /app_info_settings/{settingId} {
      allow read, write: if true; // DEV-ONLY: Open write access
    }

    match /admin_config_settings/{settingId} {
      allow read, write: if true; // DEV-ONLY: Open write access
    }

    match /loyalty_transactions/{transactionId} {
        allow read, write: if true; // DEV-ONLY: Open write access
    }

    // DEV-ONLY: Allow full access to users collection for admin panel development
    match /users/{userId} {
      allow read, write: if true;
    }
    // --- END DEVELOPMENT ONLY RULES ---


    // --- PRODUCTION User profiles rule ---
    // This rule is SECURE and should be used in production.
    // It is commented out during development to allow the admin panel to work.
    /*
    match /users/{userId} {
      // This rule requires a real authenticated user. It will not work with the auth bypass.
      // To create a user profile, you would need to disable the bypass and sign up properly.
      allow create: if request.auth.uid == userId;
      allow read, update: if request.auth.uid == userId;
      allow get, list: if isAdmin();
    }
    */

    // Other collections are now open for development.
  }
}
