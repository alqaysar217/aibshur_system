
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Allow public read access for essential setup collections
    match /cities/{cityId} {
      allow read: if true;
      allow write: if request.auth != null; // To be refined later
    }

    match /store_categories/{categoryId} {
      allow read: if true;
      allow write: if request.auth != null; // To be refined later
    }

    match /stores/{storeId} {
      allow read: if true;
      allow write: if request.auth != null; // To be refined later
    }

    match /product_categories/{prodCatId} {
      allow read: if true;
      allow write: if request.auth != null; // To be refined later
    }

    // Default deny for all other collections until specified
  }
}
