
{
  "entities": {
    "City": {
      "title": "City",
      "description": "Represents a city where the service is available.",
      "type": "object",
      "properties": {
        "cityId": { "type": "string", "description": "Unique identifier for the city." },
        "name_ar": { "type": "string", "description": "Arabic name of the city." },
        "name_en": { "type": "string", "description": "English name of the city." },
        "country_code": { "type": "string", "description": "Country code (e.g., 'YE')." },
        "is_active": { "type": "boolean", "description": "Whether the service is active in this city." },
        "support_number": { "type": "string", "description": "Customer support number for the city." }
      },
      "required": ["cityId", "name_ar", "country_code", "is_active", "support_number"]
    },
    "User": {
      "title": "User",
      "description": "Represents a user of the platform (client, driver, admin, or store owner).",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth User ID." },
        "phone": { "type": "string", "format": "phone", "description": "Primary phone number for OTP." },
        "role": { "type": "string", "enum": ["client", "driver", "admin", "store_owner"] },
        "full_name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "profile_image": { "type": "string", "format": "uri" },
        "city_id": { "type": "string", "description": "Reference to the City entity." },
        "store_id": { "type": "string", "description": "For store owners, reference to the Store entity." },
        "created_at": { "type": "string", "format": "date-time" },
        "last_login_at": { "type": "string", "format": "date-time" },
        "order_history": { "type": "array", "items": { "type": "string" } },
        "wallet_balance": { "type": "number", "description": "The user's current wallet balance, managed by admins." },
        "loyalty_points": { "type": "number", "description": "Total loyalty points accumulated by the user." },
        "account_status": {
          "type": "object",
          "properties": {
            "is_blocked": { "type": "boolean" },
            "reason": { "type": "string" }
          }
        },
        "driver_details": {
          "type": "object",
          "properties": {
            "vehicle_type": { "type": "string" },
            "license_plate": { "type": "string" },
            "id_card_image": { "type": "string", "format": "uri" },
            "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
            "is_online": { "type": "boolean" },
            "rating": { "type": "number" },
            "wallet_balance": { "type": "number" },
            "current_location": { "$ref": "#/entities/GeoPoint" }
          }
        },
        "vip_details": {
            "type": "object",
            "properties": {
                "isActive": { "type": "boolean" },
                "planId": { "type": "string", "description": "Reference to the VipPlan entity." },
                "planName": { "type": "string", "description": "Denormalized name of the plan." },
                "startDate": { "type": "string", "format": "date-time" },
                "expiryDate": { "type": "string", "format": "date-time" }
            }
        }
      },
      "required": ["uid", "phone", "role", "created_at", "last_login_at", "account_status"]
    },
    "StoreCategory": {
      "title": "Store Category",
      "description": "Represents a main category for stores (e.g., Restaurant, Pharmacy).",
      "type": "object",
      "properties": {
        "categoryId": { "type": "string", "description": "Unique identifier for the category." },
        "name_ar": { "type": "string" },
        "name_en": { "type": "string" },
        "image_url": { "type": "string", "format": "uri", "description": "URL for the category image." },
        "is_active": { "type": "boolean" }
      },
      "required": ["categoryId", "name_ar", "image_url", "is_active"]
    },
    "ProductCategory": {
        "title": "Product Category",
        "description": "Represents a sub-category or menu section within a specific store (e.g., Appetizers, Grills).",
        "type": "object",
        "properties": {
            "productCategoryId": { "type": "string", "description": "Unique identifier for the product category." },
            "name_ar": { "type": "string" },
            "storeId": { "type": "string", "description": "Reference to the Store." },
            "sortOrder": { "type": "number", "description": "Order for displaying categories." },
            "image_url": { "type": "string", "format": "uri", "description": "URL for the product category image." }
        },
        "required": ["productCategoryId", "name_ar", "storeId", "image_url"]
    },
    "Store": {
      "title": "Store",
      "description": "Represents a merchant's store.",
      "type": "object",
      "properties": {
        "storeId": { "type": "string" },
        "ownerUid": { "type": "string", "description": "Reference to the User (store owner)." },
        "name_ar": { "type": "string" },
        "name_en": { "type": "string" },
        "description_ar": { "type": "string" },
        "description_en": { "type": "string" },
        "logo_url": { "type": "string", "format": "uri" },
        "cover_image_url": { "type": "string", "format": "uri" },
        "city_id": { "type": "string", "description": "Reference to the City." },
        "filter_ids": { "type": "array", "items": { "type": "string" } },
        "location": { "$ref": "#/entities/GeoPoint" },
        "address_text": { "type": "string" },
        "working_hours": { "type": "object" },
        "preparation_time": { "type": "string", "description": "Estimated time to prepare an order, e.g., '20-30 minutes'."},
        "is_open": { "type": "boolean" },
        "is_active": { "type": "boolean" },
        "rating": { "type": "number" },
        "storeOwnerUid": { "type": "string", "description": "Denormalized for security rules." }
      },
      "required": ["storeId", "ownerUid", "name_ar", "city_id", "filter_ids", "location", "is_active", "storeOwnerUid"]
    },
    "Product": {
      "title": "Product",
      "description": "Represents a product sold in a store.",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "storeId": { "type": "string" },
        "productCategoryId": { "type": "string", "description": "Reference to the ProductCategory." },
        "name_ar": { "type": "string" },
        "name_en": { "type": "string" },
        "description_ar": { "type": "string" },
        "description_en": { "type": "string" },
        "main_image_url": { "type": "string", "format": "uri" },
        "base_price": { "type": "number", "description": "Price for the product if it has no variants." },
        "rating": { "type": "number" },
        "is_active": { "type": "boolean" },
        "variants": { 
            "type": "array", 
            "items": { "$ref": "#/entities/ProductVariant" },
            "description": "List of different types or sizes for the product."
        },
        "storeOwnerUid": { "type": "string", "description": "Denormalized for security rules." }
      },
      "required": ["productId", "storeId", "productCategoryId", "name_ar", "is_active", "storeOwnerUid"]
    },
    "ProductVariant": {
      "title": "Product Variant",
      "description": "Represents a variant of a product (e.g., size, color).",
      "type": "object",
      "properties": {
        "variantId": { "type": "string" },
        "name_ar": { "type": "string" },
        "name_en": { "type": "string" },
        "price": { "type": "number" },
        "image_url": { "type": "string", "format": "uri", "description": "Optional image for this specific variant." }
      },
      "required": ["variantId", "name_ar", "price"]
    },
    "Order": {
      "title": "Order",
      "description": "Represents a customer's order.",
      "type": "object",
      "properties": {
        "orderId": { "type": "string" },
        "clientUid": { "type": "string" },
        "driverUid": { "type": "string" },
        "storeId": { "type": "string" },
        "items": { "type": "array", "items": { "$ref": "#/entities/OrderItem" } },
        "subtotal_price": { "type": "number" },
        "delivery_fee": { "type": "number" },
        "total_price": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "accepted", "preparing", "out_for_delivery", "delivered", "cancelled", "rejected"] },
        "payment_method": { "type": "string", "enum": ["cash", "wallet", "card"] },
        "delivery_location": { "$ref": "#/entities/GeoPoint" },
        "delivery_address_text": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" },
        "storeOwnerUid": { "type": "string", "description": "Denormalized for security rules." }
      },
      "required": ["orderId", "clientUid", "storeId", "items", "total_price", "status", "payment_method", "delivery_location", "created_at", "updated_at", "storeOwnerUid"]
    },
    "OrderItem": {
      "title": "Order Item",
      "description": "Represents an item within an order.",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "productName_ar": { "type": "string" },
        "quantity": { "type": "number" },
        "price": { "type": "number" },
        "variantId": { "type": "string" },
        "variantName_ar": { "type": "string" }
      },
      "required": ["productId", "productName_ar", "quantity", "price"]
    },
    "FinanceTransaction": {
      "title": "Finance Transaction",
      "description": "Represents a financial transaction.",
      "type": "object",
      "properties": {
        "transactionId": { "type": "string" },
        "userUid": { "type": "string" },
        "orderId": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["top-up", "withdrawal", "order_payment", "refund", "system_fee", "points_conversion", "vip_subscription"] },
        "status": { "type": "string", "enum": ["pending", "completed", "failed"] },
        "description": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["transactionId", "userUid", "amount", "type", "status", "created_at"]
    },
    "AdBanner": {
      "title": "Ad Banner",
      "description": "Represents a clickable banner in the app for promotions.",
      "type": "object",
      "properties": {
        "bannerId": { "type": "string" },
        "image_url": { "type": "string", "format": "uri" },
        "is_active": { "type": "boolean" },
        "sort_order": { "type": "number" },
        "target_type": { "type": "string", "enum": ["general", "store", "product"] },
        "target_id": { "type": "string", "description": "ID of the store or product to link to." }
      },
      "required": ["bannerId", "image_url", "is_active", "sort_order", "target_type"]
    },
    "Coupon": {
      "title": "Coupon",
      "description": "Represents a discount coupon.",
      "type": "object",
      "properties": {
        "couponId": { "type": "string" },
        "code": { "type": "string" },
        "discount_type": { "type": "string", "enum": ["percentage", "fixed_amount"] },
        "discount_value": { "type": "number" },
        "min_order_value": { "type": "number" },
        "expiry_date": { "type": "string", "format": "date-time" },
        "usage_limit": { "type": "number", "description": "Total number of times the coupon can be used." },
        "scope": { "type": "string", "enum": ["global", "store", "product"] },
        "scope_ids": {
          "type": "array",
          "items": { "type": "string" },
          "description": "The IDs of the stores or products the coupon applies to."
        },
        "is_active": { "type": "boolean" }
      },
      "required": ["couponId", "code", "discount_type", "discount_value", "expiry_date", "scope", "is_active"]
    },
    "AppBank": {
      "title": "Application Bank Account",
      "description": "Represents a bank account owned by the application for receiving payments.",
      "type": "object",
      "properties": {
        "bankId": { "type": "string", "description": "Unique identifier for the bank account entry." },
        "bank_name": { "type": "string", "description": "The name of the bank (e.g., 'بنك الكريمي')." },
        "account_number": { "type": "string", "description": "The bank account number." },
        "account_holder": { "type": "string", "description": "The name of the account holder." },
        "iban": { "type": "string", "description": "The IBAN for the account (optional)." },
        "bank_logo": { "type": "string", "format": "uri", "description": "URL for the bank's logo." },
        "is_active": { "type": "boolean", "description": "Whether this account is currently active for use." }
      },
      "required": ["bankId", "bank_name", "account_number", "account_holder", "bank_logo", "is_active"]
    },
    "WalletTopupRequest": {
      "title": "Wallet Top-up Request",
      "description": "Represents a user's request to add funds to their wallet via bank transfer.",
      "type": "object",
      "properties": {
        "transactionId": { "type": "string", "description": "Unique identifier for the transaction request." },
        "userId": { "type": "string", "description": "The UID of the user making the request." },
        "user_phone": { "type": "string", "description": "Denormalized phone number of the user for display." },
        "user_name": { "type": "string", "description": "Denormalized name of the user for display." },
        "amount": { "type": "number", "description": "The amount of money transferred." },
        "receipt_number": { "type": "string", "description": "The transaction/receipt number from the bank (optional)." },
        "receipt_image": { "type": "string", "format": "uri", "description": "URL of the uploaded receipt image (optional)." },
        "bank_id": { "type": "string", "description": "ID of the AppBank entity that received the deposit." },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"], "description": "The current status of the request." },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the request was submitted." },
        "type": { "type": "string", "enum": ["manual_topup", "client_request"], "description": "The type of top-up request." },
        "rejection_reason": { "type": "string", "description": "Reason for rejection, if applicable." },
        "processed_by": { "type": "string", "description": "UID of the admin who processed the request." },
        "processed_at": { "type": "string", "format": "date-time", "description": "When the request was processed." }
      },
      "required": ["transactionId", "userId", "user_phone", "user_name", "amount", "bank_id", "status", "timestamp"]
    },
    "AppInfoSetting": {
      "title": "App Info Setting",
      "description": "Publicly accessible application information like 'About Us' or ad banners.",
      "type": "object",
      "properties": {
        "settingId": { "type": "string" },
        "type": { "type": "string", "enum": ["about_us", "privacy_policy", "terms_of_service", "ad_banner"] },
        "content_ar": { "type": "string" },
        "content_en": { "type": "string" },
        "image_url": { "type": "string", "format": "uri" },
        "is_active": { "type": "boolean" }
      },
      "required": ["settingId", "type", "content_ar", "is_active"]
    },
    "AdminConfigSetting": {
      "title": "Admin Config Setting",
      "description": "Admin-only system configurations like coupons or VIP packages.",
      "type": "object",
      "properties": {
        "settingId": { "type": "string" },
        "type": { "type": "string", "enum": ["coupon", "vip_package", "loyalty_points_config", "system_fee_config"] },
        "config_data": { "type": "object" },
        "is_active": { "type": "boolean" }
      },
      "required": ["settingId", "type", "config_data", "is_active"]
    },
    "Donation": {
      "title": "Donation",
      "description": "Represents a donation made through the system.",
      "type": "object",
      "properties": {
        "donationId": { "type": "string" },
        "userId": { "type": "string", "description": "UID of the user who donated, if known." },
        "userName": { "type": "string" },
        "userPhone": { "type": "string" },
        "donationType": { "type": "string", "enum": ["siquia", "itiam"], "description": "Type of donation." },
        "amount": { "type": "number" },
        "receiptNumber": { "type": "string" },
        "receiptImage": { "type": "string", "format": "uri" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["donationId", "donationType", "amount", "timestamp"]
    },
    "LoyaltyTransaction": {
      "title": "Loyalty Transaction",
      "description": "Represents a transaction related to loyalty points.",
      "type": "object",
      "properties": {
        "transactionId": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["earn", "redeem", "manual_adjustment"] },
        "points": { "type": "number" },
        "related_order_id": { "type": "string" },
        "related_finance_tx_id": { "type": "string" },
        "description": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["transactionId", "userId", "type", "points", "timestamp"]
    },
    "VipPlan": {
        "title": "VIP Plan",
        "description": "Defines a VIP subscription plan with its benefits.",
        "type": "object",
        "properties": {
          "planId": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string", "description": "A short description of the plan and its main features." },
          "price": { "type": "number" },
          "durationInDays": { "type": "number" },
          "benefits": {
            "type": "object",
            "properties": {
              "hasFreeDelivery": { "type": "boolean" },
              "discountPercentage": { "type": "number" },
              "pointsMultiplier": { "type": "number" }
            }
          },
          "features": {
            "type": "array",
            "items": { "type": "string" },
            "description": "A list of text-based features for the plan."
          },
          "isActive": { "type": "boolean" }
        },
        "required": ["planId", "name", "price", "durationInDays", "benefits", "isActive"]
    },
    "GeoPoint": {
        "title": "GeoPoint",
        "description": "Represents a geographical point.",
        "type": "object",
        "properties": {
            "latitude": { "type": "number" },
            "longitude": { "type": "number" }
        },
        "required": ["latitude", "longitude"]
    }
  },
  "auth": {
    "providers": ["phone"]
  },
  "firestore": {
    "/cities/{cityId}": {
      "schema": { "$ref": "#/entities/City" },
      "description": "Publicly readable list of cities where the service is available."
    },
    "/users/{uid}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profile data, private to each user."
    },
    "/store_categories/{categoryId}": {
      "schema": { "$ref": "#/entities/StoreCategory" },
      "description": "Publicly readable list of main store categories."
    },
    "/product_categories/{productCategoryId}": {
        "schema": { "$ref": "#/entities/ProductCategory" },
        "description": "Product categories/menu sections for stores. Writable by store owner."
    },
    "/stores/{storeId}": {
      "schema": { "$ref": "#/entities/Store" },
      "description": "Merchant stores, publicly readable."
    },
    "/products/{productId}": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Products for a given store, publicly readable."
    },
    "/products/{productId}/variants/{variantId}": {
      "schema": { "$ref": "#/entities/ProductVariant" },
      "description": "Variants for a given product."
    },
    "/orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "Customer orders, readable by participants."
    },
    "/financeTransactions/{transactionId}": {
      "schema": { "$ref": "#/entities/FinanceTransaction" },
      "description": "Financial transactions, private to each user."
    },
    "/app_info_settings/{settingId}": {
      "schema": { "$ref": "#/entities/AppInfoSetting" },
      "description": "Public app settings, readable by all, writable by admins."
    },
    "/admin_config_settings/{settingId}": {
      "schema": { "$ref": "#/entities/AdminConfigSetting" },
      "description": "Private system configurations, accessible only by admins."
    },
    "/ad_banners/{bannerId}": {
      "schema": { "$ref": "#/entities/AdBanner" },
      "description": "App banners. Writable by admins."
    },
    "/coupons/{couponId}": {
      "schema": { "$ref": "#/entities/Coupon" },
      "description": "Discount coupons. Writable by admins."
    },
    "/app_banks/{bankId}": {
      "schema": { "$ref": "#/entities/AppBank" },
      "description": "Bank accounts for the application, writable by admins."
    },
    "/wallet_transactions/{transactionId}": {
      "schema": { "$ref": "#/entities/WalletTopupRequest" },
      "description": "User requests to top-up their wallet. Processable by admins."
    },
    "/donations/{donationId}": {
        "schema": { "$ref": "#/entities/Donation" },
        "description": "Records of donations made."
    },
    "/loyalty_transactions/{transactionId}": {
        "schema": { "$ref": "#/entities/LoyaltyTransaction" },
        "description": "Log of all loyalty point activities."
    },
    "/vip_plans/{planId}": {
        "schema": { "$ref": "#/entities/VipPlan" },
        "description": "Defines available VIP subscription plans. Writable by admins."
    }
  }
}
    